<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Extras (Neurobooster) Content Regression" parallel="none" thread-count="1">
    <parameter name="language" value="en"/>
    <parameter name="config.profile" value="med-android"/>
    <listeners>
        <listener class-name="com.neuronation.listeners.AllureScreenshotListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    <!-- Every section + every tile's detail, distributed across the three onboarding
         flows so each flow's registration is reused. Android only (detail body is
         localisation, identical on iOS). -->
    <test name="Extras Content Regression — Android">
        <groups>
            <run>
                <include name="content"/>
            </run>
        </groups>
        <classes>
            <class name="com.neuronation.tests.med.extras.MedExtrasContentRegressionTest"/>
        </classes>
    </test>
</suite>
