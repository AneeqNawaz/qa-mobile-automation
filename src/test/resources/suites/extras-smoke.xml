<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Extras (Neurobooster) Smoke" parallel="none" thread-count="1">
    <parameter name="language" value="en"/>
    <parameter name="config.profile" value="med-android"/>
    <listeners>
        <listener class-name="com.neuronation.listeners.AllureScreenshotListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    <test name="Extras Smoke — Samsung (RZCY82DVM3P)">
        <groups>
            <run>
                <include name="extras"/>
            </run>
        </groups>
        <classes>
            <class name="com.neuronation.tests.med.extras.MedExtrasSmokeTest"/>
        </classes>
    </test>
</suite>
