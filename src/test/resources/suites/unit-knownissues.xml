<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Device-free unit suite for the known-issue quarantine logic. Runs with:
     mvn -q test -DsuiteFile=src/test/resources/suites/unit-knownissues.xml -->
<suite name="Known-Issue Unit Tests">
    <test name="known-issue-logic">
        <classes>
            <class name="com.neuronation.knownissues.KnownIssueEvaluatorTest"/>
            <class name="com.neuronation.knownissues.KnownIssueRegistryTest"/>
            <class name="com.neuronation.knownissues.KnownIssueActionTest"/>
            <class name="com.neuronation.knownissues.KnownIssueReportTest"/>
            <class name="com.neuronation.knownissues.KnownIssueTrackerTest"/>
        </classes>
    </test>
</suite>
