<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MED Full E2E Happy Path (per-flow)" parallel="none" thread-count="1">
    <parameter name="language" value="en"/>
    <parameter name="config.profile" value="med-android-emulator"/>
    <listeners>
        <listener class-name="com.neuronation.listeners.AllureScreenshotListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- Comprehensive per-flow E2E: onboarding → settings/privacy/consent verification →
         logout → login → change email → MCI → logout. Data provider runs flow1–4;
         pass -Dflow=<name> to run a single flow. -->
    <test name="Full E2E happy path">
        <classes>
            <class name="com.neuronation.tests.med.e2e.MedFullE2EHappyPathTest">
                <methods>
                    <include name="fullE2EHappyPath"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
