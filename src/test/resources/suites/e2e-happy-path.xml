<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="E2E Happy Path" parallel="methods" thread-count="1">
    <parameter name="language" value="en"/>
    <listeners>
        <listener class-name="com.neuronation.listeners.AllureScreenshotListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    <test name="MCI Full E2E to Dashboard + Profile">
        <classes>
            <!-- Only the 4 happy-path flows run here. Each asserts MCI + 90-day validity
                 inline (assertMciNinetyDayValidity), so the standalone profile test is dropped;
                 testPostLogin is excluded too (its Tips dismissal is already covered by flow1's
                 re-login). The class still exposes those methods to the other suites. -->
            <class name="com.neuronation.tests.med.e2e.MedFullE2EHappyPathTest">
                <methods>
                    <include name="testFlow1_PasswordMorningSkip"/>
                    <include name="testFlow2_PasswordEveningDoctor"/>
                    <include name="testFlow3_NoPasswordNoonColorVision"/>
                    <include name="testFlow4_PasswordNightArithmetic"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
