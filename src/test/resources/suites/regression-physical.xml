<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Full Regression — Physical Device" parallel="none" thread-count="1">
    <parameter name="language" value="en"/>
    <parameter name="config.profile" value="med-android"/>
    <listeners>
        <listener class-name="com.neuronation.listeners.AllureScreenshotListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Regression — Samsung (RZCY82DVM3P)">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.neuronation.tests.common.EdgeCaseTests"/>
            <class name="com.neuronation.tests.med.e2e.MedFullE2EHappyPathTest"/>
            <class name="com.neuronation.tests.med.e2e.MedFullRegressionE2ETest"/>
            <class name="com.neuronation.tests.med.e2e.MedLogoutLoginTest"/>
            <class name="com.neuronation.tests.med.onboarding.MedAgeGroupTest"/>
            <class name="com.neuronation.tests.med.onboarding.MedDashboardTest"/>
            <class name="com.neuronation.tests.med.onboarding.MedDoctorInfoTest"/>
            <class name="com.neuronation.tests.med.onboarding.MedEvaluationTest"/>
            <class name="com.neuronation.tests.med.onboarding.MedExerciseTest"/>
            <class name="com.neuronation.tests.med.onboarding.MedNewsletterTest"/>
            <class name="com.neuronation.tests.med.onboarding.MedPersonalizationTest"/>
            <class name="com.neuronation.tests.med.onboarding.MedProfileTest"/>
            <class name="com.neuronation.tests.med.onboarding.MedTipsTest"/>
            <class name="com.neuronation.tests.med.profile.MedSettingsVerificationTest"/>
            <class name="com.neuronation.tests.med.profile.MedProfileVerificationTest"/>
            <class name="com.neuronation.tests.med.registration.MedAppSelectionTest"/>
            <class name="com.neuronation.tests.med.registration.MedCreateAccountTest"/>
            <class name="com.neuronation.tests.med.registration.MedDiGACodeTest"/>
            <class name="com.neuronation.tests.med.registration.MedEmailRegistrationTest"/>
            <class name="com.neuronation.tests.med.registration.MedEmailVerificationTest"/>
            <class name="com.neuronation.tests.med.registration.MedLaunchTest"/>
            <class name="com.neuronation.tests.med.registration.MedOnboardingVideoTest"/>
            <class name="com.neuronation.tests.med.registration.MedPasskeyDialogTest"/>
            <class name="com.neuronation.tests.med.registration.MedSetPasswordTest"/>
        </classes>
    </test>
</suite>
