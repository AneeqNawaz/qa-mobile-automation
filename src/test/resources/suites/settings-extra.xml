<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MED Settings — Extra Read-only Verifications" parallel="none" thread-count="1">
    <parameter name="language" value="en"/>
    <parameter name="config.profile" value="med-android-emulator"/>
    <listeners>
        <listener class-name="com.neuronation.listeners.AllureScreenshotListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Age group + Training Priorities">
        <classes>
            <class name="com.neuronation.tests.med.profile.MedSettingsVerificationTest">
                <methods>
                    <include name="comparisonGroup_listsAllAgeGroups"/>
                    <include name="trainingPriorities_popupAndDomains"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
