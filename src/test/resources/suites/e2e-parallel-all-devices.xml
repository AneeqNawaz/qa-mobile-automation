<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="E2E Parallel — All Devices" parallel="tests" thread-count="3">
    <listeners>
        <listener class-name="com.neuronation.listeners.AllureScreenshotListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- Android — Samsung Physical Device -->
    <test name="Android Samsung (Physical)">
        <parameter name="language" value="en"/>
        <parameter name="config.profile" value="med-android"/>
        <classes>
            <class name="com.neuronation.tests.med.e2e.MedFullE2EHappyPathTest">
                <methods><include name="fullE2EHappyPath"/></methods>
            </class>
        </classes>
    </test>

    <!-- Android — Emulator -->
    <test name="Android Emulator">
        <parameter name="language" value="en"/>
        <parameter name="config.profile" value="med-android-emulator"/>
        <classes>
            <class name="com.neuronation.tests.med.e2e.MedFullE2EHappyPathTest">
                <methods><include name="fullE2EHappyPath"/></methods>
            </class>
        </classes>
    </test>

    <!-- iOS — iPhone Physical Device -->
    <test name="iOS iPhone (Physical)">
        <parameter name="language" value="en"/>
        <parameter name="config.profile" value="med-ios"/>
        <classes>
            <class name="com.neuronation.tests.med.e2e.MedFullE2EHappyPathTest">
                <methods><include name="fullE2EHappyPath"/></methods>
            </class>
        </classes>
    </test>
</suite>
