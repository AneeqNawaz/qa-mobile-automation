{
  "emptyPassword": {
    "expectedBehavior": "inline_error",
    "expectedError": "Please enter your password"
  },
  "shortPasswords": [
    { "password": "ab", "expectedError": "Please enter your password" },
    { "password": "123", "expectedError": "Please enter your password" },
    { "password": "a", "expectedError": "Please enter your password" }
  ],
  "weakPasswords": [
    { "password": "password", "expectedError": "password" },
    { "password": "12345678", "expectedError": "password" }
  ]
}
